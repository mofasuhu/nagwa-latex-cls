\newcommand\DeclareArabicMathOperator[5]{
  \DeclareMathOperator{#2}{\text{#4}}
  \DeclareMathOperator{#3}{\text{#5}}
  \AtBeginDocument{%
    \iftoggle{dotlessop}{\let #1 = #3}{\let #1 = #2}
  }%
}

% Alias helper (does NOT re-define the underlying operators).
% Use this to create additional command names (e.g. MathLive shortcuts)
% that point to already-declared Arabic operators, without triggering:
%   "! LaTeX Error: Command \<op> already defined."
\newcommand\DeclareArabicMathOperatorAlias[3]{%
  \AtBeginDocument{%
    \iftoggle{dotlessop}{\let #1 = #3}{\let #1 = #2}%
  }%
}

