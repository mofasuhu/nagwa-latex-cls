% Circle (hand-drawn style)
\NewDocumentCommand{\annotateCircle}{r[] m}{%
  \annot@parseidcolor{#1}%
  \annotvalidateandset{\annot@id}%
  \tikz[remember picture, baseline=(T.base)]{
    \node[anchor=base, inner sep=0pt, outer sep=0pt] (T) {#2};
  }%
  \IfAnnotEnabled{\annot@id}{%
    \tikz[remember picture, overlay]{
      \ifroughnodraw\else
        % x-radius ≈ 60% of width + 2pt padding
        \begin{ocg}{Annotations}{ocg-annotations}{1}
          % color already set by parser
          \draw[draw=\annot@colorname, line width=1pt, decorate, decoration={random steps, segment length=2.5pt, amplitude=0.7pt}] let \p1=(T.east), \p2=(T.west) in
            (T.center) ellipse [x radius={0.60*(\x1-\x2)+2pt}, y radius=1.4ex];
        \end{ocg}
      \fi
      % Extract coordinates for JSON (top-left origin, Y down)
      \path let \p1=(T.south west), \p2=(T.north east), \p3=(T.center), \p4=(T.east), \p5=(T.west),
                \p{page}=(current page.south west), \p{pagetop}=(current page.north west) in
        \pgfextra{
          \pgfmathsetmacro{\pageheight}{(\y{pagetop}-\y{page})/1pt}
          \pgfmathsetmacro{\bboxx}{(\x1-\x{page})/1pt}
          \pgfmathsetmacro{\bboxy}{\pageheight - (\y2-\y{page})/1pt}
          \pgfmathsetmacro{\bboxw}{(\x2-\x1)/1pt}
          \pgfmathsetmacro{\bboxh}{(\y2-\y1)/1pt}
          \WriteAnnotJSON{\annot@id}{circle}{\bboxx}{\bboxy}{\bboxw}{\bboxh}
        };
    }%
  }{}%
}

% Highlight (hand-drawn marker-style bar behind text)
\NewDocumentCommand{\annotateHighlight}{r[] m}{%
  \annot@parseidcolor{#1}%
  \annotvalidateandset{\annot@id}%
  \tikz[remember picture, baseline=(T.base)]{
    % Create invisible node first to get dimensions
    \node[anchor=base, inner sep=0pt, outer sep=0pt, opacity=0] (T) {#2};
    % Draw highlight behind
    \IfAnnotEnabled{\annot@id}{%
      \ifroughnodraw\else
        \begin{ocg}{Annotations}{ocg-annotations}{1}
          % color already set by parser
          \fill[fill=\annot@colorname, opacity=0.40, decorate, decoration={random steps, segment length=3pt, amplitude=0.8pt}]
            ([yshift=-2pt]T.south west) rectangle
            ([yshift= 2pt]T.north east);
        \end{ocg}
      \fi
      % Extract coordinates for JSON (top-left origin, Y down)
      \path let \p1=(T.south west), \p2=(T.north east), 
                \p3=([yshift=-2pt]T.south west), \p4=([yshift=2pt]T.north east),
                \p{page}=(current page.south west), \p{pagetop}=(current page.north west) in
        \pgfextra{
          \pgfmathsetmacro{\pageheight}{(\y{pagetop}-\y{page})/1pt}
          \pgfmathsetmacro{\bboxx}{(\x1-\x{page})/1pt}
          \pgfmathsetmacro{\bboxy}{\pageheight - (\y2-\y{page})/1pt}
          \pgfmathsetmacro{\bboxw}{(\x2-\x1)/1pt}
          \pgfmathsetmacro{\bboxh}{(\y2-\y1)/1pt}
          \WriteAnnotJSON{\annot@id}{highlight}{\bboxx}{\bboxy}{\bboxw}{\bboxh}
        };
    }{}%
    % Draw text on top
    \node[anchor=base, inner sep=0pt, outer sep=0pt] at (T.base) {#2};
  }%
}

