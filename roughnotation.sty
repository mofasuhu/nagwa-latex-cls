% roughnotation.sty
% A LaTeX package for hand-drawn annotations inspired by Rough Notation
% https://roughnotation.com
%
% Usage: \usepackage{roughnotation}
%
% Commands:
%   \annotateUnderline[id]{text}   - Hand-drawn underline
%   \annotateBox[id]{text}         - Hand-drawn box
%   \annotateCircle[id]{text}      - Hand-drawn circle/ellipse
%   \annotateHighlight[id]{text}   - Hand-drawn highlight
%   \annotateStrike[id]{text}      - Hand-drawn strike-through
%   \annotateCross[id]{text}       - Hand-drawn cross/X
%   \annotateBracket[id]{text}     - Hand-drawn brackets
%   \annotid                       - Returns current annotation ID
%
% ID values: 00 (disabled), 01-99 (enabled with ID)

\ProvidesPackage{roughnotation}[2025/10/26 v1.0 Hand-drawn annotations]

% Package options
\newif\ifroughnodraw
\DeclareOption{nodraw}{\roughnodrawtrue}
\ProcessOptions\relax

\RequirePackage{xparse}
\RequirePackage{xcolor}
\RequirePackage{tikz}
\RequirePackage{ocgx2}
\RequirePackage{xstring}
\usetikzlibrary{calc,decorations.pathmorphing,backgrounds}


% Helper to resolve color name into a palette color
% Accepts one of: black, blue, red, green, orange, purple
\newcommand{\annot@setcolor}[1]{%
  \def\annot@colorname{hwBlack}% default
  \IfStrEq{#1}{black}{\def\annot@colorname{hwBlack}}{}%
  \IfStrEq{#1}{blue}{\def\annot@colorname{hwBlue}}{}%
  \IfStrEq{#1}{red}{\def\annot@colorname{hwRed}}{}%
  \IfStrEq{#1}{green}{\def\annot@colorname{hwGreen}}{}%
  \IfStrEq{#1}{orange}{\def\annot@colorname{hwOrange}}{}%
  \IfStrEq{#1}{purple}{\def\annot@colorname{hwPurple}}{}%
}

% Parse optional bracket argument in the form ID or ID,color
% Sets \annot@id and resolves color via \annot@setcolor
\newcommand{\annot@parseidcolor}[1]{%
  \def\annot@id{#1}% default to whole string
  \def\annot@colorraw{}%
  \IfSubStr{#1}{,}{%
    \StrBefore{#1}{,}[\annot@id]%
    \StrBehind{#1}{,}[\annot@colorraw]%
  }{}%
  \annot@setcolor{\annot@colorraw}%
}

% Temporary storage for coordinate extraction
\newdimen\annot@tmp

% JSON export setup
\newwrite\annot@jsonfile
\AtBeginDocument{%
  \immediate\openout\annot@jsonfile=\jobname-annotations.json
  \immediate\write\annot@jsonfile{[}
}
\newif\iffirstannot
\firstannottrue
\AtEndDocument{%
  \immediate\write\annot@jsonfile{}
  \immediate\write\annot@jsonfile{]}
  \immediate\closeout\annot@jsonfile
}

\ExplSyntaxOn
% Accept 00 (off) or 01--99 (on with ID) — robust to spaces/catcodes
\cs_new_protected:Npn \annot_validate_id:n #1 { }
% Check if annotation is enabled (not 00)
\cs_new_protected:Npn \annot_is_enabled:n #1
  {
    \tl_set:Nn \l_tmpa_tl {#1}
    \tl_trim_spaces:N \l_tmpa_tl
    \tl_set:Nx \l_tmpa_tl { \tl_to_str:N \l_tmpa_tl }
    \str_if_eq:VnTF \l_tmpa_tl {00}
      { \c_false_bool } { \c_true_bool }
  }
\tl_new:N \g_annot_current_id_tl
\cs_new_protected:Npn \annot_set_current_id:n #1
  {
    \tl_set:Nn \l_tmpa_tl {#1}
    \tl_trim_spaces:N \l_tmpa_tl
    \tl_set:Nx \g_annot_current_id_tl { \tl_to_str:N \l_tmpa_tl }
  }
\cs_new:Npn \annotid { \tl_use:N \g_annot_current_id_tl }

% Wrapper commands that can be called from normal LaTeX
\cs_new_protected:Npn \annot_validate_and_set:n #1
  {
    \annot_validate_id:n{#1}
    \annot_set_current_id:n{#1}
  }
% Conditional command for checking if enabled
\NewDocumentCommand{\IfAnnotEnabled}{m m m}{%
  \str_if_eq:nnTF {#1} {00}
    {#3}% If 00, execute "off" branch
    {#2}% Otherwise, execute "on" branch
}
\cs_set_eq:NN \annotvalidateandset \annot_validate_and_set:n
\ExplSyntaxOff

% Helper to write JSON annotation data (id, type, bbox x/y/w/h)
\edef\openbrace{\string{}
\edef\closebrace{\string}}
\NewDocumentCommand{\WriteAnnotJSON}{m m m m m m}{%
  \iffirstannot
    \immediate\write\annot@jsonfile{  \openbrace}
    \global\firstannotfalse
  \else
    \immediate\write\annot@jsonfile{,}
    \immediate\write\annot@jsonfile{  \openbrace}
  \fi
  \immediate\write\annot@jsonfile{    "id": "#1",}
  \immediate\write\annot@jsonfile{    "type": "#2",}
  \immediate\write\annot@jsonfile{    "bbox": \openbrace "x": #3, "y": #4, "width": #5, "height": #6 \closebrace}
  \immediate\write\annot@jsonfile{  \closebrace}
}

% --------------------- Annotation Commands ---------------------

% Underline (hand-drawn style)
\NewDocumentCommand{\annotateUnderline}{r[] m}{%
  \annot@parseidcolor{#1}%
  \annotvalidateandset{\annot@id}%
  \tikz[remember picture, baseline=(T.base)]{
    \node[anchor=base, inner sep=0pt, outer sep=0pt] (T) {#2};
  }%
  \IfAnnotEnabled{\annot@id}{%
    \tikz[remember picture, overlay]{
      \ifroughnodraw\else
        \begin{ocg}{Annotations}{ocg-annotations}{1}
          % color already set by parser
          \draw[draw=\annot@colorname, line width=1pt, decorate, decoration={random steps, segment length=3pt, amplitude=0.5pt}]
            ([yshift=-1pt]T.south west) -- ([yshift=-1pt]T.south east);
        \end{ocg}
      \fi
      % Extract coordinates for JSON (top-left origin, Y down)
      \path let \p1=(T.south west), \p2=(T.north east), \p3=([yshift=-1pt]T.south west), \p4=([yshift=-1pt]T.south east),
                \p{page}=(current page.south west), \p{pagetop}=(current page.north west) in
        \pgfextra{
          \pgfmathsetmacro{\pageheight}{(\y{pagetop}-\y{page})/1pt}
          \pgfmathsetmacro{\bboxx}{(\x1-\x{page})/1pt}
          \pgfmathsetmacro{\bboxy}{\pageheight - (\y2-\y{page})/1pt}
          \pgfmathsetmacro{\bboxw}{(\x2-\x1)/1pt}
          \pgfmathsetmacro{\bboxh}{(\y2-\y1)/1pt}
          \WriteAnnotJSON{\annot@id}{underline}{\bboxx}{\bboxy}{\bboxw}{\bboxh}
        };
    }%
  }{}%
}

